@{
    Layout = null;
    var factura = ViewBag.Factura as string;
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>Factura</title>
    <style>
        body {
            font-family: Arial, Helvetica, sans-serif;
            padding: 30px;
            background-color: white;
            color: black;
        }

        h2 {
            margin-bottom: 20px;
        }

        pre {
            font-size: 16px;
            white-space: pre-wrap;
        }
    </style>
</head>
<body onload="window.print()">
    <h2>Factura</h2>

    <pre>@factura</pre>
</body>
</html>