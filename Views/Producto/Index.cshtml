@model IEnumerable<SIGRE_PYME.Models.Producto>
@using Microsoft.AspNetCore.Http

@{
    ViewData["Title"] = "Productos";
    var esAdmin = Context.Session.GetString("EsAdmin") == "true";
}

<div class="pagina-contenido">
    <div class="card shadow-sm p-4">

        <div class="d-flex justify-content-between align-items-center mb-4">
            <h2 class="mb-0">Productos</h2>

            @if (esAdmin)
            {
                <a asp-action="Create" class="btn btn-primary">Agregar producto</a>
            }
        </div>

        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger">@TempData["Error"]</div>
        }

        <div class="mb-4">
            <form method="get" asp-action="Index">

                <div class="mb-3 d-flex flex-wrap gap-2">
                    <a asp-action="Index" class="btn btn-outline-primary btn-sm">Todos</a>
                    <a asp-action="Index" asp-route-categoria="Computadoras" class="btn btn-outline-primary btn-sm">Computadoras</a>
                    <a asp-action="Index" asp-route-categoria="Mouse" class="btn btn-outline-primary btn-sm">Mouse</a>
                    <a asp-action="Index" asp-route-categoria="Teclados" class="btn btn-outline-primary btn-sm">Teclados</a>
                    <a asp-action="Index" asp-route-categoria="Audífonos" class="btn btn-outline-primary btn-sm">Audífonos</a>
                    <a asp-action="Index" asp-route-categoria="Celulares" class="btn btn-outline-primary btn-sm">Celulares</a>
                    <a asp-action="Index" asp-route-categoria="Consolas" class="btn btn-outline-primary btn-sm">Consolas</a>
                </div>

                <div class="row g-2">
                    <div class="col-md-4">
                        <input type="number" step="0.01" name="precioMin" class="form-control" placeholder="Precio mínimo" value="@ViewBag.PrecioMin" />
                    </div>

                    <div class="col-md-4">
                        <input type="number" step="0.01" name="precioMax" class="form-control" placeholder="Precio máximo" value="@ViewBag.PrecioMax" />
                    </div>

                    <div class="col-md-4">
                        <button type="submit" class="btn btn-secondary">Filtrar</button>
                        <a asp-action="Index" class="btn btn-light">Limpiar</a>
                    </div>
                </div>

            </form>
        </div>

        <div class="table-responsive">
            <table class="table table-bordered align-middle">
                <thead>
                    <tr>
                        <th>Imagen</th>
                        <th>SKU</th>
                        <th>Nombre</th>
                        <th>Categoría</th>
                        <th>Precio</th>
                        <th>Stock</th>
                        @if (esAdmin)
                        {
                            <th>Acciones</th>
                        }
                        else
                        {
                            <th>Carrito</th>
                        }
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>
                                @if (!string.IsNullOrEmpty(item.ImagenUrl))
                                {
                                    <img src="~/img/productos/@item.ImagenUrl" width="60" height="60" style="object-fit:cover;" />
                                }
                                else
                                {
                                    <span>No tiene</span>
                                }
                            </td>

                            <td>@item.SKU</td>
                            <td>@item.Nombre</td>
                            <td>@item.Categoria</td>
                            <td>@item.Precio.ToString("0.00")</td>
                            <td>@item.StockActual</td>

                            @if (esAdmin)
                            {
                                <td>
                                    <a asp-action="Edit" asp-route-id="@item.ProductoId" class="btn btn-warning btn-sm">Editar</a>
                                    <a asp-action="Delete" asp-route-id="@item.ProductoId" class="btn btn-danger btn-sm">Eliminar</a>
                                </td>
                            }
                            else
                            {
                                <td>
                                    <form asp-controller="Pedido" asp-action="AgregarAlCarrito" method="post">
                                        <input type="hidden" name="productoId" value="@item.ProductoId" />
                                        <button type="submit" class="btn btn-success btn-sm">Agregar</button>
                                    </form>
                                </td>
                            }
                        </tr>
                    }
                </tbody>
            </table>
        </div>

    </div>
</div>