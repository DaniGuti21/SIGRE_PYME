@model IEnumerable<SIGRE_PYME.Models.Producto>
@using Microsoft.AspNetCore.Http
@using SIGRE_PYME.Helpers
@{
    ViewData["Title"] = "Productos";
    var rol = Context.Session.GetString("Rol") ?? "";
    var puedeEditar = rol == RolesSistema.Admin || rol == RolesSistema.Gerente || rol == RolesSistema.Vendedor;
    var puedeEliminar = rol == RolesSistema.Admin;
    var puedeComprar = rol == RolesSistema.Cliente;
}
<div class="pagina-contenido">
    <div class="card shadow-sm p-4">
        <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-2">
            <div>
                <h2 class="mb-0">Productos</h2>
                <small class="text-secondary">Consulta, filtra y busca productos en tiempo real.</small>
            </div>
            @if (puedeEditar)
            {
                <a asp-action="Create" class="btn btn-primary">Agregar producto</a>
            }
        </div>

        @if (TempData["Mensaje"] != null)
        {
            <div class="alert alert-success">@TempData["Mensaje"]</div>
        }
        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger">@TempData["Error"]</div>
        }

        <div class="row g-2 align-items-end mb-4">
            <div class="col-lg-4">
                <label class="form-label">Buscar producto</label>
                <div class="input-group">
                    <span class="input-group-text"><i class="bi bi-search"></i></span>
                    <input id="buscadorAjax" type="text" class="form-control" placeholder="Nombre, SKU o categoría" value="@ViewBag.Texto" />
                </div>
            </div>
            <div class="col-lg-3">
                <label class="form-label">Categoría</label>
                <select id="categoriaFiltro" class="form-select">
                    <option value="">Todas</option>
                    <option selected="@(ViewBag.Categoria == "Computadoras")">Computadoras</option>
                    <option selected="@(ViewBag.Categoria == "Mouse")">Mouse</option>
                    <option selected="@(ViewBag.Categoria == "Teclados")">Teclados</option>
                    <option selected="@(ViewBag.Categoria == "Celulares")">Celulares</option>
                    <option selected="@(ViewBag.Categoria == "Tablets")">Tablets</option>
                    <option selected="@(ViewBag.Categoria == "Audífonos")">Audífonos</option>
                    <option selected="@(ViewBag.Categoria == "Consolas")">Consolas</option>
                </select>
            </div>
            <div class="col-lg-2">
                <label class="form-label">Precio mín.</label>
                <input id="precioMinFiltro" type="number" step="0.01" class="form-control" value="@ViewBag.PrecioMin" />
            </div>
            <div class="col-lg-2">
                <label class="form-label">Precio máx.</label>
                <input id="precioMaxFiltro" type="number" step="0.01" class="form-control" value="@ViewBag.PrecioMax" />
            </div>
            <div class="col-lg-1 d-grid">
                <button id="btnBuscarAjax" type="button" class="btn btn-dark"><i class="bi bi-search"></i></button>
            </div>
        </div>

        <div id="contenedorProductos" class="table-responsive">
            <table class="table table-bordered align-middle tabla-bonita">
                <thead>
                    <tr>
                        <th>Imagen</th>
                        <th>SKU</th>
                        <th>Nombre</th>
                        <th>Categoría</th>
                        <th>Precio</th>
                        <th>Stock</th>
                        <th>Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>
                                @if (!string.IsNullOrWhiteSpace(item.ImagenUrl))
                                {
                                    <img src="~/img/productos/@item.ImagenUrl" width="60" height="60" class="producto-thumb" />
                                }
                                else
                                {
                                    <span class="text-muted">Sin imagen</span>
                                }
                            </td>
                            <td>@item.SKU</td>
                            <td>@item.Nombre</td>
                            <td>@item.Categoria</td>
                            <td>₡@item.Precio.ToString("0.00")</td>
                            <td>@item.StockActual</td>
                            <td>
                                @if (puedeEditar)
                                {
                                    <a asp-action="Edit" asp-route-id="@item.ProductoId" class="btn btn-warning btn-sm">Editar</a>
                                }
                                @if (puedeEliminar)
                                {
                                    <a asp-action="Delete" asp-route-id="@item.ProductoId" class="btn btn-danger btn-sm">Eliminar</a>
                                }
                                @if (puedeComprar)
                                {
                                    <form asp-controller="Pedido" asp-action="AgregarAlCarrito" method="post" class="d-inline">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="productoId" value="@item.ProductoId" />
                                        <button type="submit" class="btn btn-success btn-sm">Agregar</button>
                                    </form>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        const puedeEditar = @puedeEditar.ToString().ToLower();
        const puedeEliminar = @puedeEliminar.ToString().ToLower();
        const puedeComprar = @puedeComprar.ToString().ToLower();

        function escapeHtml(text) {
            return $('<div>').text(text ?? '').html();
        }

        function buscarProductosAjax() {
            $.get('@Url.Action("BuscarAjax", "Producto")', {
                texto: $('#buscadorAjax').val(),
                categoria: $('#categoriaFiltro').val(),
                precioMin: $('#precioMinFiltro').val(),
                precioMax: $('#precioMaxFiltro').val()
            }).done(function (respuesta) {
                const filas = (respuesta.productos || []).map(p => {
                    const imagen = p.imagenUrl
                        ? `<img src="/img/productos/${escapeHtml(p.imagenUrl)}" width="60" height="60" class="producto-thumb" />`
                        : '<span class="text-muted">Sin imagen</span>';

                    let acciones = '';
                    if (puedeEditar) {
                        acciones += `<a href="/Producto/Edit/${p.productoId}" class="btn btn-warning btn-sm me-1">Editar</a>`;
                    }
                    if (puedeEliminar) {
                        acciones += `<a href="/Producto/Delete/${p.productoId}" class="btn btn-danger btn-sm me-1">Eliminar</a>`;
                    }
                    if (puedeComprar) {
                        acciones += `
                            <form action="/Pedido/AgregarAlCarrito" method="post" class="d-inline">
                                <input type="hidden" name="productoId" value="${p.productoId}" />
                                <button type="submit" class="btn btn-success btn-sm">Agregar</button>
                            </form>`;
                    }

                    return `<tr>
                        <td>${imagen}</td>
                        <td>${escapeHtml(p.sku)}</td>
                        <td>${escapeHtml(p.nombre)}</td>
                        <td>${escapeHtml(p.categoria)}</td>
                        <td>₡${escapeHtml(p.precio)}</td>
                        <td>${p.stockActual}</td>
                        <td>${acciones || '<span class="text-muted">Sin acciones</span>'}</td>
                    </tr>`;
                }).join('');

                $('#contenedorProductos tbody').html(filas || '<tr><td colspan="7" class="text-center text-muted">No se encontraron productos.</td></tr>');
            });
        }

        $('#btnBuscarAjax').on('click', buscarProductosAjax);
        $('#buscadorAjax').on('keyup', function (e) {
            if (e.key === 'Enter') buscarProductosAjax();
        });
        $('#categoriaFiltro, #precioMinFiltro, #precioMaxFiltro').on('change', buscarProductosAjax);
    </script>
}