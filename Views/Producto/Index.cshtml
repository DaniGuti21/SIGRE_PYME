@model IEnumerable<SIGRE_PYME.Models.Producto>
@using Microsoft.AspNetCore.Http

@{
    ViewData["Title"] = "Productos";
    var esAdmin = Context.Session.GetString("EsAdmin") == "true";
}

<div class="pagina-contenido">
    <div class="card shadow-sm p-4">

        <div class="d-flex justify-content-between mb-3">
            <h2>Productos</h2>

            @if (esAdmin)
            {
                <a asp-action="Create" class="btn btn-primary">Agregar producto</a>
            }
        </div>

        <div class="table-responsive">
            <table class="table table-bordered">
                <thead>
                    <tr>
                        <th>Imagen</th>
                        <th>SKU</th>
                        <th>Nombre</th>
                        <th>Categoría</th>
                        <th>Precio</th>
                        <th>Stock</th>
                        @if (esAdmin)
                        {
                            <th>Acciones</th>
                        }
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>
                                @if (!string.IsNullOrEmpty(item.ImagenUrl))
                                {
                                    <img src="~/img/productos/@item.ImagenUrl" width="60" height="60" />
                                }
                                else
                                {
                                    <span>No tiene</span>
                                }
                            </td>
                            <td>@item.SKU</td>
                            <td>@item.Nombre</td>
                            <td>@item.Categoria</td>
                            <td>@item.Precio</td>
                            <td>@item.StockActual</td>

                            @if (esAdmin)
                            {
                                <td>
                                    <a asp-action="Edit" asp-route-id="@item.ProductoId" class="btn btn-warning btn-sm">Editar</a>
                                    <a asp-action="Delete" asp-route-id="@item.ProductoId" class="btn btn-danger btn-sm">Eliminar</a>
                                </td>
                            }
                        </tr>
                    }
                </tbody>
            </table>
        </div>

    </div>
</div>