@model SIGRE_PYME.Models.Producto
@{
    ViewData["Title"] = "Crear producto";
}
<div class="pagina-contenido">
    <div class="card shadow-sm p-4 tarjeta-formulario">
        <h2>Crear producto</h2>
        <form asp-action="Create" method="post" enctype="multipart/form-data">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
            <div class="row g-3">
                <div class="col-md-6">
                    <label asp-for="SKU" class="form-label"></label>
                    <input asp-for="SKU" class="form-control" />
                    <span asp-validation-for="SKU" class="text-danger"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="Nombre" class="form-label"></label>
                    <input asp-for="Nombre" class="form-control" />
                    <span asp-validation-for="Nombre" class="text-danger"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="Categoria" class="form-label"></label>
                    <select asp-for="Categoria" class="form-select">
                        <option value="">Seleccione una categoría</option>
                        <option>Computadoras</option>
                        <option>Mouse</option>
                        <option>Teclados</option>
                        <option>Celulares</option>
                        <option>Tablets</option>
                        <option>Audífonos</option>
                        <option>Consolas</option>
                    </select>
                    <span asp-validation-for="Categoria" class="text-danger"></span>
                </div>
                <div class="col-md-3">
                    <label asp-for="Precio" class="form-label"></label>
                    <input asp-for="Precio" class="form-control" step="0.01" />
                    <span asp-validation-for="Precio" class="text-danger"></span>
                </div>
                <div class="col-md-3">
                    <label asp-for="StockActual" class="form-label"></label>
                    <input asp-for="StockActual" class="form-control" />
                    <span asp-validation-for="StockActual" class="text-danger"></span>
                </div>
                <div class="col-12">
                    <label class="form-label">Imagen</label>
                    <input type="file" name="imagenArchivo" class="form-control" accept="image/*" />
                </div>
            </div>
            <div class="mt-4 d-flex gap-2">
                <button type="submit" class="btn btn-success">Guardar</button>
                <a asp-action="Index" class="btn btn-outline-secondary">Volver</a>
            </div>
        </form>
    </div>
</div>
@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}