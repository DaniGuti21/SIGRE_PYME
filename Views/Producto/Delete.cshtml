@model SIGRE_PYME.Models.Producto

@{
    ViewData["Title"] = "Eliminar producto";
}

<div class="container mt-4">
    <h2>Eliminar producto</h2>

    <div class="alert alert-warning">
        ¿Está seguro que desea eliminar este producto?
    </div>

    <div class="card p-3 mb-3">
        <p><strong>SKU:</strong> @Model.SKU</p>
        <p><strong>Nombre:</strong> @Model.Nombre</p>
        <p><strong>Categoría:</strong> @Model.Categoria</p>
        <p><strong>Precio:</strong> @Model.Precio.ToString("0.00")</p>
        <p><strong>Stock:</strong> @Model.StockActual</p>

        @if (!string.IsNullOrEmpty(Model.ImagenUrl))
        {
            <div class="mt-2">
                <img src="~/img/productos/@Model.ImagenUrl" width="100" height="100" style="object-fit:cover; border-radius:8px;" />
            </div>
        }
    </div>

    <form asp-action="DeleteConfirmed" method="post">
        <input type="hidden" name="ProductoId" value="@Model.ProductoId" />
        <button type="submit" class="btn btn-danger">Eliminar</button>
        <a asp-action="Index" class="btn btn-secondary">Cancelar</a>
    </form>
</div>