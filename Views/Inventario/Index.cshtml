@model IEnumerable<SIGRE_PYME.Models.MovimientoInventario>

@{
    ViewData["Title"] = "Inventario";
}

<h2>Movimientos de Inventario</h2>

<p>
    <a asp-action="Entrada" class="btn btn-success">Registrar Entrada</a>
    <a asp-action="Salida" class="btn btn-danger">Registrar Salida</a>
</p>

<table class="table table-bordered">
    <thead>
        <tr>
            <th>ProductoId</th>
            <th>Tipo</th>
            <th>Cantidad</th>
            <th>Fecha</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.ProductoId</td>
                <td>@item.TipoMovimiento</td>
                <td>@item.Cantidad</td>
                <td>@item.Fecha</td>
            </tr>
        }
    </tbody>
</table>