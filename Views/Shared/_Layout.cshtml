@using Microsoft.AspNetCore.Http

@{
    var usuarioId = Context.Session.GetString("UsuarioId");
    var nombreUsuario = Context.Session.GetString("NombreUsuario");
    var esAdmin = Context.Session.GetString("EsAdmin") == "true";
    var estaLogueado = !string.IsNullOrEmpty(usuarioId);
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - SIGRE_PYME</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-dark bg-primary shadow-sm mb-4">
            <div class="container">
                <a class="navbar-brand fw-bold" asp-controller="Usuario" asp-action="Login">SIGRE_PYME</a>

                <div class="navbar-nav ms-auto">
                    @if (!estaLogueado)
                    {
                        <a class="nav-link text-white" asp-controller="Usuario" asp-action="Login">Login</a>
                        <a class="nav-link text-white" asp-controller="Usuario" asp-action="Registro">Registro</a>
                    }
                    else
                    {
                        <a class="nav-link text-white" asp-controller="Producto" asp-action="Index">Productos</a>

                        @if (esAdmin)
                        {
                            <a class="nav-link text-white" asp-controller="Inventario" asp-action="Index">Inventario</a>
                            <a class="nav-link text-white" asp-controller="Cliente" asp-action="Index">Clientes</a>
                        }

                        <span class="nav-link text-white">Bienvenido, @nombreUsuario</span>

                        <a class="nav-link text-white" asp-controller="Usuario" asp-action="CerrarSesion">Cerrar sesión</a>
                    }
                </div>
            </div>
        </nav>
    </header>

    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

    @RenderSection("Scripts", required: false)
</body>
</html>