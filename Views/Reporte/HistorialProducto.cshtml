@model IEnumerable<SIGRE_PYME.Models.MovimientoInventario>

@{
    ViewData["Title"] = "Historial por producto";
}

<div class="pagina-contenido">
    <div class="card shadow-sm p-4">
        <h2>Historial de movimientos por producto</h2>

        <form method="get" asp-action="HistorialProducto" class="mb-3">
            <label class="form-label">Producto</label>
            <select name="productoId" asp-items="ViewBag.Productos" class="form-control"></select>
            <button type="submit" class="btn btn-primary mt-2">Ver historial</button>
        </form>

        <table class="table table-bordered">
            <thead>
                <tr>
                    <th>Producto</th>
                    <th>Tipo</th>
                    <th>Cantidad</th>
                    <th>Fecha</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@item.Producto?.Nombre</td>
                        <td>@item.TipoMovimiento</td>
                        <td>@item.Cantidad</td>
                        <td>@item.Fecha</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>