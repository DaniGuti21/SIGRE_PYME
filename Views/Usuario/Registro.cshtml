@model SIGRE_PYME.Models.Usuario

@{
    ViewData["Title"] = "Registro";
}

<div class="pantalla-auth">
    <div class="tarjeta-auth registro-activo">
        <div class="encabezado-auth">
            <h2>Crear cuenta</h2>
            <p>Regístrate para ingresar al sistema</p>
        </div>

        <form method="post">
            <div class="mb-3">
                <label class="form-label">Usuario</label>
                <input name="NombreUsuario" type="text" class="form-control input-auth" placeholder="Cree su usuario" required />
            </div>

            <div class="mb-3">
                <label class="form-label">Contraseña</label>
                <input name="Contrasena" type="password" class="form-control input-auth" placeholder="Cree su contraseña" required />
            </div>

            <button class="btn btn-danger boton-auth w-100">Registrarse</button>
        </form>

        @if (ViewBag.Error != null)
        {
            <p class="mensaje-error mt-3">@ViewBag.Error</p>
        }

        <div class="enlace-auth">
            <span>¿Ya tienes cuenta?</span>
            <a href="/Usuario/Login">Iniciar sesión</a>
        </div>
    </div>
</div>