@model SIGRE_PYME.ViewModels.RegistroUsuarioViewModel
@using Microsoft.AspNetCore.Mvc.Rendering
@{
    ViewData["Title"] = "Registro";
    var roles = ViewBag.Roles as List<SelectListItem> ?? new List<SelectListItem>();
}

<div class="pantalla-auth">
    <div class="tarjeta-auth registro-activo">
        <div class="encabezado-auth">
            <h2>Crear cuenta</h2>
            <p>Registra un usuario del sistema</p>
        </div>

        @if (ViewBag.Error != null)
        {
            <div class="alert alert-danger">@ViewBag.Error</div>
        }

        <form asp-action="Registro" method="post">
            @Html.AntiForgeryToken()

            <div class="mb-3">
                <label asp-for="NombreUsuario" class="form-label"></label>
                <input asp-for="NombreUsuario" class="form-control input-auth" />
                <span asp-validation-for="NombreUsuario" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="RolId" class="form-label">Rol</label>
                <select asp-for="RolId" asp-items="roles" class="form-select input-auth"></select>
                <span asp-validation-for="RolId" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Contrasena" class="form-label"></label>
                <input asp-for="Contrasena" class="form-control input-auth" />
                <span asp-validation-for="Contrasena" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="ConfirmarContrasena" class="form-label"></label>
                <input asp-for="ConfirmarContrasena" class="form-control input-auth" />
                <span asp-validation-for="ConfirmarContrasena" class="text-danger"></span>
            </div>

            <button class="btn btn-danger boton-auth w-100" type="submit">Registrarse</button>
        </form>

        <div class="enlace-auth">
            <span>¿Ya tienes cuenta?</span>
            <a asp-controller="Usuario" asp-action="Login">Iniciar sesión</a>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}