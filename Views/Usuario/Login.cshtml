@model SIGRE_PYME.Models.Usuario

@{
    ViewData["Title"] = "Login";
}

<div class="pantalla-auth">
    <div class="tarjeta-auth login-activo">
        <div class="encabezado-auth">
            <h2>Bienvenido</h2>
            <p>Inicia sesión para continuar en el sistema</p>
        </div>

        <form method="post">
            <div class="mb-3">
                <label class="form-label">Usuario</label>
                <input name="NombreUsuario" type="text" class="form-control input-auth" placeholder="Ingrese su usuario" required />
            </div>

            <div class="mb-3">
                <label class="form-label">Contraseña</label>
                <input name="Contrasena" type="password" class="form-control input-auth" placeholder="Ingrese su contraseña" required />
            </div>

            <button class="btn btn-primary boton-auth w-100">Ingresar</button>
        </form>

        @if (ViewBag.Error != null)
        {
            <p class="mensaje-error mt-3">@ViewBag.Error</p>
        }

        <div class="enlace-auth">
            <span>¿No tienes cuenta?</span>
            <a href="/Usuario/Registro">Crear cuenta</a>
        </div>
    </div>
</div>