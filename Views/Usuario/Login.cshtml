@model SIGRE_PYME.Models.Usuario

<div class="container mt-5">
    <div class="col-md-4 mx-auto">
        <div class="card p-4 shadow">
            <h3 class="text-center">Iniciar Sesión</h3>

            <form method="post">
                <input name="Email" class="form-control mb-3" placeholder="Correo" />
                <input name="Contrasena" type="password" class="form-control mb-3" placeholder="Contraseña" />

                <button class="btn btn-primary w-100">Ingresar</button>
            </form>

            <p class="text-danger">@ViewBag.Error</p>

            <div class="text-center mt-3">
                <a href="/Usuario/Registro">Crear cuenta</a>
            </div>
        </div>
    </div>
</div>