@model SIGRE_PYME.ViewModels.LoginViewModel
@{
    ViewData["Title"] = "Login";
}
<div class="pantalla-auth">
    <div class="tarjeta-auth login-activo">
        <div class="encabezado-auth">
            <h2>Bienvenido</h2>
            <p>Inicia sesión para continuar en el sistema</p>
        </div>

        @if (TempData["Mensaje"] != null)
        {
            <div class="alert alert-success">@TempData["Mensaje"]</div>
        }
        @if (ViewBag.Error != null)
        {
            <div class="alert alert-danger">@ViewBag.Error</div>
        }

        <form asp-action="Login" method="post">
            @Html.AntiForgeryToken()
            <div class="mb-3">
                <label asp-for="NombreUsuario" class="form-label">Usuario</label>
                <input asp-for="NombreUsuario" class="form-control input-auth" placeholder="Ingrese su usuario" />
                <span asp-validation-for="NombreUsuario" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Contrasena" class="form-label">Contraseña</label>
                <input asp-for="Contrasena" class="form-control input-auth" placeholder="Ingrese su contraseña" />
                <span asp-validation-for="Contrasena" class="text-danger"></span>
            </div>

            <button class="btn btn-primary boton-auth w-100" type="submit">Ingresar</button>
        </form>

        <div class="enlace-auth">
            <span>¿No tienes cuenta?</span>
            <a asp-controller="Usuario" asp-action="Registro">Crear cuenta</a>
        </div>
    </div>
</div>
@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}