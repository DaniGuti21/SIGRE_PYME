@{
    ViewData["Title"] = "Contacto";
}

<div class="pagina-contenido">
    <div class="caja-contacto">
        <h2>Contáctanos</h2>

        <form>
            <div class="mb-3">
                <label class="form-label">Nombre completo</label>
                <input type="text" class="form-control" placeholder="Ingrese su nombre completo" />
            </div>

            <div class="mb-3">
                <label class="form-label">Número de teléfono</label>
                <input type="text" class="form-control" placeholder="Ingrese su número" />
            </div>

            <div class="mb-3">
                <label class="form-label">Correo electrónico</label>
                <input type="email" class="form-control" placeholder="Ingrese su correo" />
            </div>

            <div class="mb-3">
                <label class="form-label">¿Cómo podemos ayudarle?</label>
                <textarea class="form-control" rows="4" placeholder="Escriba su mensaje aquí"></textarea>
            </div>

            <button type="submit" class="btn btn-dark">Enviar</button>
        </form>
    </div>
</div>